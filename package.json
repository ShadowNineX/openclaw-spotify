{
  "name": "@shadowninex/openclaw-spotify",
  "version": "0.1.1",
  "description": "Spotify integration plugin for OpenClaw",
  "type": "module",
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target bun --format esm --external openclaw --external typebox --external @shadownine/foxify",
    "check": "tsc --noEmit",
    "plugin:build": "bun run build && openclaw plugins build --root . --entry ./dist/index.js",
    "plugin:validate": "bun run build && openclaw plugins validate --root . --entry ./dist/index.js",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "openclaw": "2026.6.11",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11",
    "typescript": "^6.0.3"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "clawhubSpec": "shadowninex/openclaw-spotify",
      "defaultChoice": "clawhub"
    },
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": "2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  },
  "dependencies": {
    "@shadownine/foxify": "^0.1.2",
    "typebox": "1.3.4"
  }
}
