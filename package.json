{
  "name": "openclaw-spotify",
  "version": "0.1.0",
  "description": "Spotify integration plugin for OpenClaw",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "openclaw": "2026.6.11",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11",
    "typescript": "^6.0.3"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": "2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  },
  "dependencies": {
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "typebox": "1.1.39"
  }
}
